# OPENAI_API_KEY: Required for OpenAI API calls.
# Configure this via your deployment/runtime secrets manager.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# PORT: Optional backend API port.
PORT=8787

# STYLE_REFERENCE_IMAGE_PATH: Optional default style image (repo-relative or absolute).
# When set, room/element generation uses this file if the request body omits styleReference.
# Example: pic/style1.png
STYLE_REFERENCE_IMAGE_PATH=pic/style1.png

# ---- Hotel review module (mounted at /api/hotel-review/v1) ----
# SQLite file path for hotel-review evidence snapshots.
DB_PATH=./data/evidence-gap.sqlite
# CSV inputs used by `npm run bootstrap:hotel-review`.
# You can put files under data/hotel-import/ (paths relative to repo root when you run npm from root):
# DESCRIPTION_CSV=./data/hotel-import/Description_PROC.csv
# REVIEWS_CSV=./data/hotel-import/Reviews_PROC.csv
# Or use absolute paths anywhere on disk.
DESCRIPTION_CSV=./data/hotel-import/Description_PROC.csv
REVIEWS_CSV=./data/hotel-import/Reviews_PROC.csv
RECENT_WINDOW_DAYS=180
PENDING_REVIEW_LAG_DAYS=14
ASK_THRESHOLD=0.55
OPENAI_MODEL=gpt-5
ENABLE_AI_RERANK=true

# Vite (frontend): optional fixed property for "Rate your stay" suggested questions.
# If unset, the UI uses the first row from GET /api/hotel-review/v1/properties.
# VITE_HOTEL_REVIEW_PROPERTY_ID=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
